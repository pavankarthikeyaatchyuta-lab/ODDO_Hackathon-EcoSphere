POSTGRES_USER=ecosphere
POSTGRES_PASSWORD=ecosphere_pass
POSTGRES_DB=ecosphere_db
DATABASE_URL=postgresql://ecosphere:ecosphere_pass@postgres:5432/ecosphere_db
SECRET_KEY=change_this_to_a_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# AI — tries Groq first, falls back to Ollama automatically
# Groq (free cloud): get a key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# Ollama (local fallback): install from https://ollama.com, then run: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3
NEXT_PUBLIC_API_URL=http://localhost:8000
